@{
    ViewData["Title"] = "My Dashboard";
    var developerName = ViewBag.DeveloperName as string ?? "Developer";
    var projects = ViewBag.Projects as List<PCOMS.Models.Project> ?? new List<PCOMS.Models.Project>();
    var tasks = ViewBag.Tasks as List<PCOMS.Models.TaskItem> ?? new List<PCOMS.Models.TaskItem>();
}

<div class="container-fluid mt-4">
    <!-- Welcome Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5 fw-bold">
                <i class="bi bi-hand-wave text-primary"></i>
                Hello, @developerName!
            </h1>
            <p class="text-muted fs-5">Welcome to your workspace</p>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                                <i class="bi bi-folder2-open text-primary fs-2"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">My Projects</h6>
                            <h2 class="mb-0">@ViewBag.TotalProjects</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                                <i class="bi bi-list-task text-warning fs-2"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Active Tasks</h6>
                            <h2 class="mb-0">@ViewBag.ActiveTasks</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-success bg-opacity-10 rounded-3 p-3">
                                <i class="bi bi-check-circle text-success fs-2"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Completed</h6>
                            <h2 class="mb-0">@ViewBag.CompletedTasks</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-info bg-opacity-10 rounded-3 p-3">
                                <i class="bi bi-clock text-info fs-2"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Hours This Week</h6>
                            <h2 class="mb-0">@ViewBag.HoursThisWeek</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="row g-4">
        <!-- Left: Projects -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-kanban me-2"></i>My Projects
                        </h5>
                        <a href="@Url.Action("MyProjects", "Developer")" class="btn btn-sm btn-outline-primary">
                            View All
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (projects.Any())
                    {
                        <div class="row g-3">
                            @foreach (var project in projects.Take(4))
                            {
                                <div class="col-md-6">
                                    <div class="card h-100 border shadow-sm">
                                        <div class="card-body">
                                            <span class="badge bg-primary mb-2">@project.Status</span>
                                            <h6 class="card-title fw-bold">@project.Name</h6>
                                            <p class="text-muted small mb-2">
                                                <i class="bi bi-building me-1"></i>@project.Client?.Name
                                            </p>
                                            <small class="text-muted">
                                                <i class="bi bi-calendar"></i> @project.StartDate.ToString("MMM dd, yyyy")
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-inbox display-4 text-muted mb-2"></i>
                            <p class="text-muted">No projects assigned yet</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right: Tasks -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-list-check me-2"></i>My Tasks
                        </h5>
                        <a href="@Url.Action("MyTasks", "Developer")" class="btn btn-sm btn-outline-primary">
                            View All
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (tasks.Any())
                    {
                        @foreach (var task in tasks.Take(8))
                        {
                            <div class="d-flex justify-content-between align-items-start mb-3 pb-3 border-bottom">
                                <div class="flex-grow-1">
                                    <h6 class="mb-1">@task.Title</h6>
                                    <small class="text-muted">@task.Project?.Name</small>
                                    <br>
                                    <small class="text-muted">
                                        <i class="bi bi-calendar"></i> Due: @task.DueDate?.ToString("MMM dd")
                                    </small>
                                </div>
                                <span class="badge bg-@(task.Status == TaskStatus.Completed ? "success" : "warning")">
                                    @task.Status
                                </span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-check-circle display-4 text-muted mb-2"></i>
                            <p class="text-muted">No tasks assigned</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>