@model List<PCOMS.Models.Project>

@{
    ViewData["Title"] = "My Projects";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-kanban me-2"></i>My Projects</h2>
    </div>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var project in Model)
            {
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <span class="badge bg-primary mb-2">@project.Status</span>
                            <h5 class="card-title">@project.Name</h5>
                            <p class="text-muted mb-2">
                                <i class="bi bi-building me-1"></i>@project.Client?.Name
                            </p>
                            <p class="card-text text-muted small">
                                @(string.IsNullOrEmpty(project.Description) ? "No description" :
                                                        project.Description.Length > 100 ? project.Description.Substring(0, 100) + "..." : project.Description)
                    </p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <small class="text-muted">
                            <i class="bi bi-calendar"></i> @project.StartDate.ToString("MMM dd, yyyy")
                        </small>
                    </div>
                </div>
            </div>
        </div>
                }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>No projects assigned to you yet.
        </div>
    }
</div>